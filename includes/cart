
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>주문작성</title>

    <style>
        body{ margin:0; background:#f5f5f7; font-family:'Apple SD Gothic Neo',sans-serif; }
        .wrap{ max-width:600px; margin:0 auto; padding:20px; }
        .cart-item{ background:#fff; padding:15px; margin-bottom:10px; border-radius:12px; }
        .form-box{ background:#fff; padding:20px; border-radius:15px; margin-top:20px; }
        input{ width:100%; padding:12px; margin-bottom:8px; border:1px solid #ddd; border-radius:8px; box-sizing:border-box; }
        .bottom{ background:#fff; padding:20px; border-radius:15px; margin-top:20px; }
        .pay-btn{ width:100%; padding:15px; background:#007AFF; color:#fff; border:none; border-radius:10px; cursor:pointer; font-size:16px; margin-bottom:8px; }
        .bank-btn{ width:100%; padding:15px; background:#111; color:#fff; border:none; border-radius:10px; cursor:pointer; font-size:16px; }
    </style>

    <script src="https://cdn.portone.io/v2/browser-sdk.js"></script>
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
        import { getFirestore, collection, addDoc } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBzHogA2iaUQqOOsNVL55stsdMH8lCQ4Ek",
            authDomain: "ecogr-636c6.firebaseapp.com",
            projectId: "ecogr-636c6",
            storageBucket: "ecogr-636c6.firebasestorage.app",
            messagingSenderId: "95745358447",
            appId: "1:95745358447:web:94cde53f6b36e6be95eb9a"
        };
        const app = initializeApp(firebaseConfig);
        window.db = getFirestore(app);
        window.addDoc = addDoc;
        window.collection = collection;
    </script>
</head>
<body>

<div class="wrap">
    <h1>🛒 주문작성</h1>
    <div id="cart-list"></div>
    <div class="form-box">
        <h3>주문자 정보</h3>
        <input id="name" placeholder="성함"/>
        <input id="phone" placeholder="전화번호(오기입시 결제창이 호출되지 않습니다.)"/>
        <input id="address" placeholder="주소"/>
        <input id="detailAddress" placeholder="상세주소"/>
    </div>
    <div class="bottom">
        <div id="total-price">총 결제금액 : 0원</div>
        <button class="pay-btn" onclick="goCard()">카드결제</button>
        <button class="bank-btn" onclick="goBankTransfer()">무통장 입금</button>
    </div>
</div>

<script>
// 각 결제 수단별 독립적인 Worker 주소
const WORKER_CARD = "https://proud-math-2d41.ecogr.workers.dev/";

let cart = JSON.parse(localStorage.getItem("cart")) || [];
let total = 0;

function render(){
    const list = document.getElementById("cart-list");
    list.innerHTML = "";
    total = 0;
    cart.forEach((item,index)=>{
        total += Number(item.price);
        list.innerHTML += `
        <div class="cart-item">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
                <div>
                    <b>${item.item}</b> (${item.qty}개)<br/>
                    ${item.width} × ${item.height}<br/>
                    ${Number(item.price).toLocaleString()}원
                </div>
                <button onclick="deleteItem(${index})" style="background:#ff3b30; color:#fff; border:none; padding:8px 12px; border-radius:6px; cursor:pointer;">삭제</button>
            </div>
        </div>`;
    });
    document.getElementById("total-price").innerText = "총 결제금액 : " + total.toLocaleString() + "원";
}

window.deleteItem = function(index){
    cart.splice(index,1);
    localStorage.setItem("cart",JSON.stringify(cart));
    render();
};

async function saveOrderToFirestore(orderData) {
    try {
        await addDoc(collection(window.db, "orders"), {
            ...orderData,
            status: (orderData.payment === "무통장입금") ? "입금대기" : "결제완료"
        });
    } catch (e) {
        console.error("Firestore 저장 실패:", e);
    }
}

function saveOrder(type, paymentId){
    const name = document.getElementById("name").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const address = document.getElementById("address").value.trim() + " " + document.getElementById("detailAddress").value.trim();
    const orderData = { orderId: paymentId, name, phone, address, total, items: cart, payment: type, createdAt: new Date().toISOString() };
    localStorage.setItem("latestOrder", JSON.stringify(orderData));
    return orderData;
}

// [1] 카드 결제 전용 (KCP)
window.goCard = async function() {
    try {
        const res = await fetch(WORKER_CARD);
        const data = await res.json();
        processPayment("카드결제", "CARD", "KRW", data.CHANNEL_KEY_CARD, data.STORE_ID);
    } catch (e) { alert("카드 서버 연결 실패"); }
};



// [3] 핵심 결제 처리 엔진 (공통)
async function processPayment(paymentType, payMethod, currency, channelKey, storeId) {
    const name = document.getElementById("name").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const address = document.getElementById("address").value.trim() + " " + document.getElementById("detailAddress").value.trim();

    if(!name || !phone || !address.trim()){ alert("정보를 모두 입력해주세요."); return; }

    try {
        const paymentId = "PAY_" + Date.now();
        const orderData = saveOrder(paymentType, paymentId);

        

        if(response.code != null){ alert("결제 실패: " + response.message); return; }

        await saveOrderToFirestore(orderData);
        localStorage.removeItem("cart");
        location.href = "success.html";
    } catch(error) {
        console.error(error);
        alert("결제창 호출 실패. 서버 연결을 확인하세요.");
    }
}

window.goBankTransfer = async function(){
    const name = document.getElementById("name").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const address = document.getElementById("address").value.trim() + " " + document.getElementById("detailAddress").value.trim();
    if(!name || !phone || !address.trim()){ alert("모든 정보를 입력해주세요."); return; }
    const orderId = "BANK_" + Date.now();
    const orderData = saveOrder("무통장입금", orderId);
    await saveOrderToFirestore(orderData);
    localStorage.removeItem("cart");
    location.href = "success2.html";
};


window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    // 'price' 값이 넘어왔는지 확인하여 실행
    if (params.has('price')) {
        const newItem = {
            item: params.get('item') || '커스텀 인쇄물',
            qty: params.get('qty') || 1,
            width: params.get('width'),
            height: params.get('height'),
            price: params.get('price'),
            compositeImage: params.get('compositeImage') // 넘겨받은 시안 합본 파일명
        };
        
        // 중복 추가 방지: 같은 가격/상품인 경우 제외
        if (!cart.some(c => c.price === newItem.price && c.compositeImage === newItem.compositeImage)) {
            cart.push(newItem);
            localStorage.setItem("cart", JSON.stringify(cart));
            // URL 파라미터 정리
            window.history.replaceState({}, document.title, window.location.pathname);
            render();
        }
    }
});

render();
</script>

</body>
</html>
