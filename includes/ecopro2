// 전역 변수로 선언해서 어디서든 쓸 수 있게 함
let orderData = {};

window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    
    // 1. 반복문을 통해 모든 파라미터를 한 번에 객체로 변환
    for (const [key, value] of urlParams.entries()) {
        orderData[key] = decodeURIComponent(value);
    }

    // 2. 후가공 리스트가 있다면 배열로 별도 저장
    if (orderData.finishings) {
        orderData.finishingsArray = orderData.finishings.split(',');
    }

    console.log("받아온 주문 정보:", orderData);

});
